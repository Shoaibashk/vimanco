{
  "name": "vimanco",
  "displayName": "Vimanco - Vim Configuration Manager",
  "description": "Opinionated Vim keybindings and settings manager for VSCodeVim.",
  "version": "1.0.0",
  "icon": "Assets/keybinding.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shoaibashk/vimanco"
  },
  "publisher": "shoaibashk",
  "license": "Apache-2.0",
  "extensionDependencies": [
    "vscodevim.vim"
  ],
  "keywords": [
    "vim",
    "vi",
    "shoaibashk",
    "vimanco"
  ],
  "homepage": "https://github.com/Shoaibashk/vimanco",
  "bugs": {
    "url": "https://github.com/Shoaibashk/vimanco/issues"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vimanco.updateVim",
        "title": "Vimanco: Update Vim Settings"
      },
      {
        "command": "vimanco.resetToDefaults",
        "title": "Vimanco: Reset Settings to Defaults"
      }
    ],
    "configuration": {
      "title": "Vimanco",
      "properties": {
        "vimanco.useSystemClipboard": {
          "type": "boolean",
          "default": true,
          "description": "Enable Vim use-system-clipboard integration."
        },
        "vimanco.easyMotion": {
          "type": "boolean",
          "default": true,
          "description": "Enable EasyMotion plugin for Vim."
        },
        "vimanco.incSearch": {
          "type": "boolean",
          "default": true,
          "description": "Enable incremental search in Vim."
        },
        "vimanco.hlSearch": {
          "type": "boolean",
          "default": true,
          "description": "Enable search highlight in Vim."
        },
        "vimanco.insertModeKeyBindings": {
          "type": "array",
          "default": [
            {
              "before": [
                "j",
                "j"
              ],
              "after": [
                "<Esc>"
              ]
            }
          ],
          "description": "Insert mode key bindings passed to VSCodeVim."
        },
        "vimanco.normalModeKeyBindingsNonRecursive": {
          "type": "array",
          "default": [
            {
              "before": [
                "<leader>",
                "d"
              ],
              "after": [
                "d",
                "d"
              ]
            },
            {
              "before": [
                "K"
              ],
              "commands": [
                "lineBreakInsert"
              ],
              "silent": true
            }
          ],
          "description": "Normal mode non-recursive key bindings passed to VSCodeVim."
        },
        "vimanco.leader": {
          "type": "string",
          "default": "<space>",
          "description": "Vim leader key."
        },
        "vimanco.handleKeys": {
          "type": "object",
          "default": {
            "<C-a>": false,
            "<C-f>": false,
            "<C-x>": false,
            "<C-c>": false,
            "<C-v>": false,
            "<C-z>": false,
            "<C-n>": false,
            "<tab>": false
          },
          "description": "Keys to let VS Code handle rather than Vim (passed to vim.handleKeys)."
        },
        "vimanco.visualModeKeyBindingsNonRecursive": {
          "type": "array",
          "default": [],
          "description": "Visual mode non-recursive key bindings passed to VSCodeVim."
        },
        "vimanco.surround": {
          "type": "boolean",
          "default": true,
          "description": "Enable vim-surround plugin for Vim."
        },
        "vimanco.sneak": {
          "type": "boolean",
          "default": false,
          "description": "Enable vim-sneak plugin for Vim."
        },
        "vimanco.smartcase": {
          "type": "boolean",
          "default": true,
          "description": "Override ignorecase if search pattern contains uppercase letters."
        },
        "vimanco.ignorecase": {
          "type": "boolean",
          "default": true,
          "description": "Ignore case in search patterns."
        },
        "vimanco.camelCaseMotion": {
          "type": "boolean",
          "default": false,
          "description": "Enable CamelCaseMotion plugin for Vim."
        },
        "vimanco.preset": {
          "type": "string",
          "default": "default",
          "enum": ["minimal", "default", "full"],
          "enumDescriptions": [
            "Minimal: only clipboard and leader key.",
            "Default: standard settings (recommended).",
            "Full: all plugins and bindings enabled."
          ],
          "description": "Apply a curated preset of Vimanco settings. Individual settings still override the preset."
        }
      }
    },
    "keybindings": [
      {
        "key": "ctrl+n",
        "command": "workbench.action.files.newUntitledFile"
      },
      {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus "
      },
      {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus "
      },
      {
        "key": "ctrl+`",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
      },
      {
        "key": "ctrl+k",
        "command": "-extension.vim_ctrl+k",
        "when": "editorTextFocus && vim.active && vim.use<C-k> && !inDebugRepl"
      },
      {
        "key": "shift+alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+ctrl+k",
        "command": "editor.action.copyLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+ctrl+j",
        "command": "editor.action.copyLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+t",
        "command": "-extension.vim_ctrl+t",
        "when": "editorTextFocus && vim.active && vim.use<C-t> && !inDebugRepl"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "pkgupdate": "gulp update && vsce package"
  },
  "devDependencies": {
    "gulp": "^4.0.2",
    "gulp-bump": "^3.2.0",
    "gulp-cli": "^2.3.0",
    "gulp-git": "^2.10.1",
    "gulp-tag-version": "^1.3.1",
    "yargs": "^17.7.2",
    "@types/vscode": "^1.84.0",
    "@types/mocha": "^10.0.3",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2",
    "ts-loader": "^9.5.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "@vscode/test-electron": "^2.3.6"
  }
}
